# EC2 Environment Configuration
# Copy this file to .env.ec2 and update with your AWS credentials

AWS_REGION=us-east-1

# AWS RDS MySQL Configuration
AWS_RDS_ENDPOINT=your-rds-endpoint.rds.amazonaws.com
AWS_RDS_PORT=3306
AWS_RDS_USERNAME=admin
AWS_RDS_PASSWORD=your-secure-password

# AWS ElastiCache Redis Configuration
AWS_REDIS_ENDPOINT=your-redis-endpoint.cache.amazonaws.com
AWS_REDIS_PORT=6379

# Application Configuration
SPRING_ENVIRONMENT=prod
LOG_LEVEL=INFO
